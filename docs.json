{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "Xyra Bulk SMS",
    "description": "Developer documentation for the Xyra Bulk SMS HTTP API. Send single or bulk SMS to Kenyan mobile networks, query delivery receipts, and check account balance.",
    "colors": {
        "primary": "#05d0dc",
        "light": "#22e3ee",
        "dark": "#0891a0"
    },
    "favicon": "/favicon.svg",
    "logo": {
        "light": "/logo/light.svg",
        "dark": "/logo/dark.svg",
        "href": "https://bulksms.xyratechnology.co.ke"
    },
    "background": {
        "color": {
            "light": "#ffffff",
            "dark": "#0a0a0a"
        }
    },
    "appearance": {
        "default": "system"
    },
    "navbar": {
        "links": [
            {
                "label": "Dashboard",
                "href": "https://bulksms.xyratechnology.co.ke"
            },
            {
                "label": "Support",
                "href": "mailto:hello@xyratechnology.co.ke"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Get API Key",
            "href": "https://bulksms.xyratechnology.co.ke"
        }
    },
    "footer": {
        "socials": {
            "website": "https://xyratechnology.co.ke",
            "x": "https://x.com/xyratechnology"
        }
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Documentation",
                "groups": [
                    {
                        "group": "Get Started",
                        "pages": [
                            "introduction",
                            "quickstart",
                            "authentication"
                        ]
                    },
                    {
                        "group": "Core Concepts",
                        "pages": [
                            "concepts/sender-ids",
                            "concepts/delivery-receipts",
                            "concepts/encoding"
                        ]
                    },
                    {
                        "group": "Reference",
                        "pages": [
                            "errors",
                            "changelog"
                        ]
                    }
                ]
            },
            {
                "tab": "API Reference",
                "groups": [
                    {
                        "group": "Messaging",
                        "pages": [
                            "api-reference/send-sms",
                            "api-reference/send-bulk-sms"
                        ]
                    },
                    {
                        "group": "Delivery",
                        "pages": [
                            "api-reference/get-delivery-report"
                        ]
                    },
                    {
                        "group": "Account",
                        "pages": [
                            "api-reference/get-balance",
                            "api-reference/network-status"
                        ]
                    }
                ]
            }
        ]
    },
    "api": {
        "openapi": "openapi.yaml",
        "playground": {
            "display": "interactive"
        },
        "examples": {
            "languages": [
                "curl",
                "javascript",
                "python",
                "php"
            ]
        }
    },
    "seo": {
        "metatags": {
            "og:title": "Xyra Bulk SMS — API Documentation",
            "og:description": "Send bulk SMS in Kenya via HTTP. Sub-second delivery, per-message DLR, simple JSON API."
        },
        "indexing": "navigable"
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude"
        ]
    }
}